# AIGI-Holmes 配置文件（桌面安装版默认使用 SQLite，开箱即用）
# 如需切换到 PostgreSQL，取消注释并修改下方 DATABASE_URL

# 数据库（默认 SQLite，无需额外安装）
DATABASE_URL=sqlite+aiosqlite:///./aigi_holmes.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aigi_holmes

# Redis 缓存（可选；未连接时自动跳过缓存，不影响核心功能）
REDIS_URL=redis://localhost:6379/0

# JWT 密钥（生产环境请修改为随机字符串）
SECRET_KEY=aigi-holmes-secret-key-change-in-production

# 角色管理密码（管理员在“角色管理”弹窗中输入）
ADMIN_ROLE_PASSWORD=aigi

# 模型权重路径（相对于程序目录）
MODEL_PATH=finetuned_fake_real_resnet50.pth

# 豆包 AI 分析功能（可选；留空则禁用 AI 分析）
DOUBAO_API_KEY=134b784a-d045-47a3-bd79-ebc8590d6de5
DOUBAO_MODEL=ep-20260407120210-7hb2t

# Serper 联网搜索 API（新闻/图片搜索功能；留空则禁用搜索）
# 申请地址: https://serper.dev
SERPER_API_KEY=39ef1dbabc26b918c01ee99b8570e34d9e44bdff
